# Copy to /srv/hermes-medical/config/.env and chmod 600.
# No Telegram bot token is needed here for MVP: the existing Hermes Telegram gateway is used.

MEDICAL_DATA_DIR=/srv/hermes-medical/data
MEDICAL_DB_PATH=/srv/hermes-medical/data/db/medical.sqlite
HERMES_MEDICAL_PROFILE=medical_agent

# Optional only for future standalone helper calls.
# Basic MVP uses existing Hermes provider credentials/OAuth.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
