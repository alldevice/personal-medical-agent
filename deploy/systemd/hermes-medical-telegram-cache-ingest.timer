[Unit]
Description=Run Hermes medical Telegram cache ingest periodically
Documentation=https://github.com/alldevice/personal-medical-agent/blob/main/docs/RUNBOOK.md

[Timer]
OnBootSec=2min
OnUnitActiveSec=2min
AccuracySec=30s
Persistent=true
Unit=hermes-medical-telegram-cache-ingest.service

[Install]
WantedBy=timers.target
